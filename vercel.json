{
  "version": 2,
  "builds": [
    {
      "src": "api/donghub.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/donghub.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
